# ─────────────────────────────────────────────────────────────
# RaccontiInValigia — Variabili Next.js
# Copia in web/.env.local e compila con i tuoi valori
# ─────────────────────────────────────────────────────────────

# Supabase — chiave pubblica (anon key, sicura per il browser)
# Trovala in: supabase.com → tuo progetto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon key

# Google Books API (opzionale — usata lato server nell'API route isbn-lookup)
GOOGLE_BOOKS_API_KEY=
