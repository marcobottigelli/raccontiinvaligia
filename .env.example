# ─────────────────────────────────────────────────────────────
# RaccontiInValigia — Variabili d'ambiente
# Copia questo file in .env e compila con i tuoi valori
# ─────────────────────────────────────────────────────────────

# Supabase (progetto RaccontiInValigia — separato da RigHouse)
# Trovalo in: supabase.com → tuo progetto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key (per script Python)

# Google Books API (opzionale — aumenta il rate limit da ~1000/day a 1000/100sec)
# Ottienila su: console.cloud.google.com → Librerie → Books API
GOOGLE_BOOKS_API_KEY=
